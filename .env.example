# --------------------------------------------------------------------
# Digital Contract Hub — environment template
# Copy this file to `.env` and fill in real values.
# Never commit `.env` (it is gitignored).
# --------------------------------------------------------------------

# Which LLM provider to use for answer generation and OCR API fallback.
# Accepted values: gemini | openai | anthropic
LLM_PROVIDER=gemini

# --- Gemini (recommended demo provider) ----------------------------
# Get a key from https://aistudio.google.com/
GEMINI_API_KEY=
# Working demo model verified against the current free tier.
GEMINI_MODEL=gemini-2.5-flash-lite
# OCR vision model used when PaddleOCR-VL falls back to the API.
GEMINI_OCR_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Optional: comma-separated models the app may try in order if the
# primary GEMINI_MODEL is rate-limited (NOT yet auto-applied in code —
# documented here for the planned fallback chain).
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash

# --- OpenAI (optional alternative provider) ------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_OCR_MODEL=gpt-4.1-mini

# --- Anthropic / Claude (optional alternative provider) ------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_OCR_MODEL=claude-haiku-4-5-20251001

# --- OCR pipeline --------------------------------------------------
# Local OCR engine. The current build ships only PaddleOCR-VL 1.5;
# this var is kept for future engine swaps (e.g. tesseract, surya).
OCR_ENGINE=paddleocr_vl
# Device for the local OCR model. Accepted: cpu | gpu | gpu:0 ...
# Use `cpu` if no CUDA GPU is available — Paddle still loads but
# inference will be slow.
OCR_DEVICE=gpu:0
# If local OCR returns empty text or fails, transparently retry the
# page through the configured vision LLM.
OCR_FALLBACK_ENABLED=true
# Which provider answers OCR fallback calls. Defaults to LLM_PROVIDER
# when unset. Accepted: gemini | openai | anthropic
OCR_API_FALLBACK_PROVIDER=gemini
